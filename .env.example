# ─────────────────────────────────────────────────────────────
#  trace · environment template
#  Values below match the bundled docker-compose.yml so the
#  dev loop works out-of-the-box.
# ─────────────────────────────────────────────────────────────

# Drizzle / Postgres (matches docker-compose.yml)
DATABASE_URL="postgres://trace:trace@localhost:55432/trace"

# Public URL the browser uses to reach trace. Required in production
# (used by Better Auth for cookie scope + CSRF). Local dev: leave empty
# or set to http://localhost:5173.
ORIGIN=""

# Host port mapped to the app container (docker-compose.yml `app` service).
TRACE_PORT="7777"

# Auth secret — 32+ random characters in production (openssl rand -hex 32).
TRACE_AUTH_SECRET=""

# First sign-up with this email becomes the instance admin. Leave empty
# to skip bootstrap (you'll need to promote a user manually in DB).
TRACE_BOOTSTRAP_ADMIN_EMAIL=""

# OIDC (Keycloak / Auth0 / any standard OIDC provider) — optional.
# Leave all three empty to disable the SSO button and fall back to email/password.
OIDC_DISCOVERY_URL=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# S3 / MinIO (matches docker-compose.yml). The MinIO container reuses
# S3_ACCESS_KEY / S3_SECRET_KEY as its root credentials — change them
# both together if you redeploy on a reachable network.
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="trace-attachments"
S3_ACCESS_KEY="trace"
S3_SECRET_KEY="tracetrace"
