# Drizzle / Postgres (matches docker-compose.yml)
DATABASE_URL="postgres://trace:trace@localhost:55432/trace"

# App
ORIGIN=""

# Auth secret — 32+ random characters in production (openssl rand -hex 32)
TRACE_AUTH_SECRET=""

# OIDC (Keycloak / Auth0 / any standard OIDC provider) — optional.
# Leave all three empty to disable the SSO button and fall back to email/password.
OIDC_DISCOVERY_URL=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# S3 / MinIO (matches docker-compose.yml)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="trace-attachments"
S3_ACCESS_KEY="trace"
S3_SECRET_KEY="tracetrace"
